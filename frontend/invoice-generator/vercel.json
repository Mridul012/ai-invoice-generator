{
    "builds": [
        {
            "src": "frontend/invoice-generator/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}